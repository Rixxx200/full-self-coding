#!/bin/sh
# post-commit：提交完成后再次同步 commit_message（双保险）

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null) || exit 0
case "$GIT_DIR" in /*|[a-zA-Z]:*) ;; *) GIT_DIR="$REPO_ROOT/$GIT_DIR" ;; esac

RECORD_FILE="$GIT_DIR/ai-cr-record-id"
ROOT_FILE="$GIT_DIR/ai-cr-root"
[ -f "$RECORD_FILE" ] || exit 0

RECORD_ID=$(tr -d '\r\n' < "$RECORD_FILE")
[ -n "$RECORD_ID" ] || exit 0

if [ -f "$ROOT_FILE" ]; then
    AI_CR_ROOT=$(tr -d '\r\n' < "$ROOT_FILE")
else
    AI_CR_ROOT=$(cd "$(dirname "$0")/.." && pwd)
fi
rm -f "$RECORD_FILE" "$ROOT_FILE"

SYNC_SCRIPT="$AI_CR_ROOT/scripts/sync_commit_message.py"
PY=$(command -v python3 2>/dev/null || command -v python 2>/dev/null)
[ -n "$PY" ] && [ -f "$SYNC_SCRIPT" ] && \
    "$PY" "$SYNC_SCRIPT" \
        --record-id "$RECORD_ID" \
        --ai-cr-root "$AI_CR_ROOT" \
        --from-last-commit \
        --repo-root "$REPO_ROOT"
exit 0
